{
  "name": "identity-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/identity-service/src",
  "projectType": "application",
  "tags": ["scope:identity", "type:service"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "env": { "NODE_ENV": "production" },
        "cwd": "apps/identity-service"
      },
      "configurations": {
        "development": { "env": { "NODE_ENV": "development" } }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "identity-service:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": { "buildTarget": "identity-service:build:development" },
        "production": { "buildTarget": "identity-service:build:production" }
      }
    },
    "test": { "options": { "passWithNoTests": true } },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --build tsconfig.json --emitDeclarationOnly --force",
        "cwd": "apps/identity-service"
      }
    }
  }
}
