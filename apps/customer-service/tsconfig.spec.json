{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "types": [
      "jest",
      "node"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/application/testing/**/*.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    { "path": "../../libs/shared/result/tsconfig.lib.json" },
    { "path": "../../libs/shared/interceptors/tsconfig.lib.json" },
    { "path": "../../libs/shared/validation/tsconfig.lib.json" }
  ]
}
