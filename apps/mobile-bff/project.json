{
  "name": "mobile-bff",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile-bff/src",
  "projectType": "application",
  "tags": ["scope:mobile-bff", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "env": { "NODE_ENV": "production" },
        "cwd": "apps/mobile-bff"
      },
      "configurations": {
        "development": { "env": { "NODE_ENV": "development" } }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "mobile-bff:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": { "buildTarget": "mobile-bff:build:development" },
        "production": { "buildTarget": "mobile-bff:build:production" }
      }
    },
    "test": { "options": { "passWithNoTests": true } }
  }
}
